    });
    addGuard(level2, 3, 4, RIGHT, PATROL_GUARD);
    levels.push_back(move(level2));

    Level level3 = makeLevel("Silent Maze - Complex Patrol Pattern", {
        "###########################",
        "#@.......................$#",
        "#..#########..#########...#",
        "#..#.......#..#.......#...#",
        "#..#..###..#..#..###..#...#",
        "#..#.......#..........#...#",
