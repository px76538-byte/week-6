using namespace std;

// ------------------------------------------------------------
// Basic types
// ------------------------------------------------------------

struct Position {
    int row = 0;
    int col = 0;
};

bool operator==(const Position& left, const Position& right) {
    return left.row == right.row && left.col == right.col;
}

bool operator!=(const Position& left, const Position& right) {
    return !(left == right);
}

enum class Direction {
    Up,
    Right,
    Down,
    Left
};

enum class MoveResult {
    Moved,
    Blocked,
    Caught
};

char directionSymbol(Direction direction) {
    switch (direction) {
        case Direction::Up:    return '^';
        case Direction::Right: return '>';
        case Direction::Down:  return 'v';
        case Direction::Left:  return '<';
    }

    return '?';
}

string directionName(Direction direction) {
    switch (direction) {
        case Direction::Up:    return "up";
        case Direction::Right: return "right";
        case Direction::Down:  return "down";
        case Direction::Left:  return "left";
    }

    return "unknown";
}

Direction oppositeDirection(Direction direction) {
    switch (direction) {
        case Direction::Up:    return Direction::Down;
        case Direction::Right: return Direction::Left;
        case Direction::Down:  return Direction::Up;
        case Direction::Left:  return Direction::Right;
    }

    return Direction::Up;
}

Direction turnClockwise(Direction direction) {
    switch (direction) {
        case Direction::Up:    return Direction::Right;
        case Direction::Right: return Direction::Down;
        case Direction::Down:  return Direction::Left;
        case Direction::Left:  return Direction::Up;
    }

    return Direction::Up;
}

Position nextPosition(Position current, Direction direction) {
    switch (direction) {
        case Direction::Up:    current.row--; break;
        case Direction::Right: current.col++; break;
        case Direction::Down:  current.row++; break;
        case Direction::Left:  current.col--; break;
    }

    return current;
}

// ------------------------------------------------------------
// Guard hierarchy: runtime polymorphism is used so each guard
// type can respond differently when it encounters an obstacle.
// ------------------------------------------------------------

class Guard {
private:
    Position position;
    Direction direction;

protected:
    void setDirection(Direction newDirection) {
        direction = newDirection;
    }

public:
    Guard(Position startPosition, Direction startDirection)
        : position(startPosition), direction(startDirection) {
    }

    virtual ~Guard() = default;

    Position getPosition() const {
        return position;
    }

    void setPosition(Position newPosition) {
        position = newPosition;
    }

    Direction getDirection() const {
        return direction;
    }

    virtual void turnWhenBlocked() = 0;
    virtual bool movesAfterTurning() const = 0;
    virtual string typeName() const = 0;
    virtual string blockedBehavior() const = 0;
    virtual unique_ptr<Guard> clone() const = 0;
};

class LineGuard : public Guard {
public:
    LineGuard(Position startPosition, Direction startDirection)
        : Guard(startPosition, startDirection) {
    }

    void turnWhenBlocked() override {
        setDirection(oppositeDirection(getDirection()));
    }

    bool movesAfterTurning() const override {
        return false;
    }

    string typeName() const override {
        return "normal line guard";
    }

    string blockedBehavior() const override {
        return "reverses direction and waits until its next turn";
    }

    unique_ptr<Guard> clone() const override {
        return make_unique<LineGuard>(*this);
    }
};

class PatrolGuard : public Guard {
public:
    PatrolGuard(Position startPosition, Direction startDirection)
        : Guard(startPosition, startDirection) {
    }

    void turnWhenBlocked() override {
        setDirection(turnClockwise(getDirection()));
    }

    bool movesAfterTurning() const override {
        return true;
    }

    string typeName() const override {
        return "patrolling guard";
    }

    string blockedBehavior() const override {
        return "turns clockwise and moves if the new tile is open";
    }

    unique_ptr<Guard> clone() const override {
        return make_unique<PatrolGuard>(*this);
    }
};

// ------------------------------------------------------------
// Level objects
// ------------------------------------------------------------

struct Door {
    Position position;
    char group = 'A';
    bool open = false;
};

struct SwitchTile {
    Position position;
    char group = 'A';
};

struct Level {
    string name;
    vector<string> map;
    Position player;
    Position goal;
    vector<unique_ptr<Guard>> guards;
    vector<Door> doors;
    vector<SwitchTile> switches;

    Level() = default;

    // Deep copy is needed because unique_ptr cannot be copied normally.
    // clone() gives every copied level its own independent guards.
    Level(const Level& other)
        : name(other.name),
          map(other.map),
          player(other.player),
          goal(other.goal),
          doors(other.doors),
          switches(other.switches) {
        for (const auto& guard : other.guards) {
            guards.push_back(guard->clone());
        }
    }

    Level& operator=(const Level& other) {
        if (this == &other) {
            return *this;
        }

        name = other.name;
        map = other.map;
        player = other.player;
        goal = other.goal;
        doors = other.doors;
        switches = other.switches;

        guards.clear();
        for (const auto& guard : other.guards) {
            guards.push_back(guard->clone());
        }

        return *this;
    }

    Level(Level&&) noexcept = default;
    Level& operator=(Level&&) noexcept = default;
};

// ------------------------------------------------------------
// Input helpers
// ------------------------------------------------------------

string trim(const string& text) {
    size_t first = 0;
    while (first < text.size() &&
           isspace(static_cast<unsigned char>(text[first]))) {
        first++;
    }

    size_t last = text.size();
    while (last > first &&
           isspace(static_cast<unsigned char>(text[last - 1]))) {
        last--;
    }

    return text.substr(first, last - first);
}

string toLower(string text) {
    for (char& character : text) {
        character = static_cast<char>(
            tolower(static_cast<unsigned char>(character))
        );
    }

    return text;
}

bool parseStrictInt(const string& text, int& value) {
    stringstream input(text);
    input >> value;

    if (input.fail()) {
        return false;
    }

    input >> ws;
    return input.eof();
}

bool parseTwoStrictInts(const string& text, int& first, int& second) {
    stringstream input(text);
    input >> first >> second;

    if (input.fail()) {
        return false;
    }

    input >> ws;
    return input.eof();
}

bool readLine(const string& prompt, string& result) {
    cout << prompt;
    return static_cast<bool>(getline(cin, result));
}

bool promptForInteger(const string& prompt, int& value) {
    while (true) {
        string input;
        if (!readLine(prompt, input)) {
            return false;
        }

        if (parseStrictInt(trim(input), value)) {
            return true;
        }

        cout << "Please enter one whole number.\n";
    }
}

// ------------------------------------------------------------
// Searching and collision helpers
// ------------------------------------------------------------

bool inBounds(const Level& level, Position position) {
    return position.row >= 0 &&
           position.row < static_cast<int>(level.map.size()) &&
           position.col >= 0 &&
           position.col < static_cast<int>(level.map[position.row].size());
}

int findDoor(const Level& level, Position position) {
    for (int index = 0;
         index < static_cast<int>(level.doors.size());
         index++) {
        if (level.doors[index].position == position) {
            return index;
        }
    }

    return -1;
}

int findSwitch(const Level& level, Position position) {
    for (int index = 0;
         index < static_cast<int>(level.switches.size());
         index++) {
        if (level.switches[index].position == position) {
            return index;
        }
    }

    return -1;
}

int findGuard(const Level& level, Position position) {
    for (int index = 0;
         index < static_cast<int>(level.guards.size());
         index++) {
        if (level.guards[index]->getPosition() == position) {
            return index;
        }
    }

    return -1;
}

bool closedDoorAt(const Level& level, Position position) {
    int doorIndex = findDoor(level, position);
    return doorIndex != -1 && !level.doors[doorIndex].open;
}

bool blocksMovement(const Level& level, Position position) {
    if (!inBounds(level, position)) {
        return true;
    }

    if (level.map[position.row][position.col] == '#') {
        return true;
    }

    return closedDoorAt(level, position);
}

bool guardTileBlocked(const Level& level,
                      Position position,
                      int movingGuardIndex) {
    if (blocksMovement(level, position)) {
        return true;
    }

    for (int index = 0;
         index < static_cast<int>(level.guards.size());
         index++) {
        if (index != movingGuardIndex &&
            level.guards[index]->getPosition() == position) {
            return true;
        }
    }

    return false;
}

bool blocksVision(const Level& level, Position position) {
    if (!inBounds(level, position)) {
        return true;
    }

    if (level.map[position.row][position.col] == '#') {
        return true;
    }

    return closedDoorAt(level, position);
}

// ------------------------------------------------------------
// Doors and switches
// ------------------------------------------------------------

void toggleDoors(Level& level, char group) {
    bool foundDoor = false;
    bool nowOpen = false;

    for (Door& door : level.doors) {
        if (door.group == group) {
            door.open = !door.open;
            nowOpen = door.open;
            foundDoor = true;
        }
    }

    if (foundDoor) {
        cout << "Switch " << static_cast<char>(tolower(group))
             << " changed door group " << group << " to "
             << (nowOpen ? "open" : "closed") << ".\n";
    }
}

void activateSwitchAt(Level& level, Position position) {
    int switchIndex = findSwitch(level, position);

    if (switchIndex != -1) {
        toggleDoors(level, level.switches[switchIndex].group);
    }
}

// ------------------------------------------------------------
// Level creation
// ------------------------------------------------------------

void addLineGuard(Level& level,
                  int row,
                  int col,
                  Direction direction) {
    level.guards.push_back(
        make_unique<LineGuard>(Position{row, col}, direction)
    );
}

void addPatrolGuard(Level& level,
                    int row,
                    int col,
                    Direction direction) {
    level.guards.push_back(
        make_unique<PatrolGuard>(Position{row, col}, direction)
    );
}

void validateMapShape(const vector<string>& map) {
    if (map.empty() || map[0].empty()) {
        throw runtime_error("A level map cannot be empty.");
    }

    const size_t width = map[0].size();
    for (const string& row : map) {
        if (row.size() != width) {
            throw runtime_error("Every row in a level must have the same width.");
        }
    }
}

void extractMapObjects(Level& level) {
    int playerCount = 0;
    int goalCount = 0;

    level.guards.clear();
    level.doors.clear();
    level.switches.clear();

    for (int row = 0; row < static_cast<int>(level.map.size()); row++) {
        for (int col = 0;
             col < static_cast<int>(level.map[row].size());
             col++) {
            char tile = level.map[row][col];
            Position position{row, col};

            if (tile == '@') {
                level.player = position;
                level.map[row][col] = '.';
                playerCount++;
            }
            else if (tile == '$') {
                level.goal = position;
                level.map[row][col] = '.';
                goalCount++;
            }
            else if (tile == '<') {
                addLineGuard(level, row, col, Direction::Left);
                level.map[row][col] = '.';
            }
            else if (tile == '>') {
                addLineGuard(level, row, col, Direction::Right);
                level.map[row][col] = '.';
            }
            else if (tile == '^') {
                addLineGuard(level, row, col, Direction::Up);
                level.map[row][col] = '.';
            }
            else if (tile == 'v') {
                addLineGuard(level, row, col, Direction::Down);
                level.map[row][col] = '.';
            }
            else if (tile >= 'A' && tile <= 'Z') {
                level.doors.push_back(Door{position, tile, false});
                level.map[row][col] = '.';
            }
            else if (tile >= 'a' && tile <= 'z') {
                char group = static_cast<char>(
                    toupper(static_cast<unsigned char>(tile))
                );
                level.switches.push_back(SwitchTile{position, group});
                level.map[row][col] = '.';
            }
        }
    }

    if (playerCount != 1 || goalCount != 1) {
        throw runtime_error(
            "Every level must contain exactly one @ player and one $ goal."
        );
    }
}

Level makeLevel(const string& name, const vector<string>& originalMap) {
    validateMapShape(originalMap);

    Level level;
    level.name = name;
    level.map = originalMap;
    extractMapObjects(level);
    return level;
}

