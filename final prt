// ------------------------------------------------------------
// Display and inspection
// ------------------------------------------------------------

char displayTile(const Level& level, Position position) {
    if (level.player == position) {
        return '@';
    }

    int guardIndex = findGuard(level, position);
    if (guardIndex != -1) {
        return directionSymbol(level.guards[guardIndex]->getDirection());
    }

    int doorIndex = findDoor(level, position);
    if (doorIndex != -1) {
        if (level.doors[doorIndex].open) {
            return '/';
        }
        return level.doors[doorIndex].group;
    }

    int switchIndex = findSwitch(level, position);
    if (switchIndex != -1) {
        return static_cast<char>(
            tolower(static_cast<unsigned char>(
                level.switches[switchIndex].group
            ))
        );
    }

    if (level.goal == position) {
        return '$';
    }

    return level.map[position.row][position.col];
}

void printMap(const Level& level) {
    cout << "\n" << level.name << "\n";
    cout << "Move: W/A/S/D   Inspect: inspect ROW COLUMN   Quit: Q\n\n";

    cout << "   ";
    for (int col = 0; col < static_cast<int>(level.map[0].size()); col++) {
        cout << col % 10;
    }
    cout << '\n';

    for (int row = 0; row < static_cast<int>(level.map.size()); row++) {
        if (row < 10) {
            cout << ' ';
        }
        cout << row << ' ';

        for (int col = 0;
             col < static_cast<int>(level.map[row].size());
             col++) {
            cout << displayTile(level, Position{row, col});
        }
        cout << '\n';
    }

    cout << "\nLegend: @ player, # wall, $ goal, < > ^ v normal guard,\n"
         << "        A-Z closed door groups, a-z switches, / open door\n";
}

void inspectTile(const Level& level, Position position) {
    cout << "\nInspecting row " << position.row
         << ", column " << position.col << ":\n";

    if (!inBounds(level, position)) {
        cout << "That position is outside the level.\n";
        return;
    }

    if (level.player == position) {
        cout << "Player: You are standing on this tile.\n";
        return;
    }

    int guardIndex = findGuard(level, position);
    if (guardIndex != -1) {
        const Guard& guard = *level.guards[guardIndex];
        cout << "Guard: This is a " << guard.typeName() << ".\n";
        cout << "It is facing " << directionName(guard.getDirection()) << ".\n";
        cout << "When blocked, it " << guard.blockedBehavior() << ".\n";

        Position forward = nextPosition(
            guard.getPosition(),
            guard.getDirection()
        );

        if (guardTileBlocked(level, forward, guardIndex)) {
            cout << "The tile directly in front of it is currently blocked.\n";

            if (guard.movesAfterTurning()) {
                Direction turned = turnClockwise(guard.getDirection());
                Position afterTurn = nextPosition(guard.getPosition(), turned);

                if (guardTileBlocked(level, afterTurn, guardIndex)) {
                    cout << "The tile after its clockwise turn is also blocked, "
                         << "so it will remain in place.\n";
                }
                else {
                    cout << "After turning, it can move to row "
                         << afterTurn.row << ", column " << afterTurn.col
                         << ".\n";
                }
            }
        }
        else {
            cout << "Its next move is toward row " << forward.row
                 << ", column " << forward.col << ".\n";
        }

        return;
    }

    int doorIndex = findDoor(level, position);
    if (doorIndex != -1) {
        const Door& door = level.doors[doorIndex];
        cout << "Door: Group " << door.group << ". It is "
             << (door.open ? "open" : "closed") << ".\n";

        if (door.open) {
            cout << "Players, guards, and guard vision can pass through it.\n";
        }
        else {
            cout << "It blocks players, guards, and guard vision.\n";
        }
        return;
    }

    int switchIndex = findSwitch(level, position);
    if (switchIndex != -1) {
        const SwitchTile& switchTile = level.switches[switchIndex];
        cout << "Switch: This controls door group "
             << switchTile.group << ".\n";
        cout << "A player or guard stepping on it toggles that door group.\n";
        return;
    }

    if (level.goal == position) {
        cout << "Goal: Reach this tile to complete the level.\n";
        return;
    }

    if (level.map[position.row][position.col] == '#') {
        cout << "Wall: It blocks movement and guard vision.\n";
        return;
    }

    cout << "Empty floor tile.\n";
}

bool handleInspectCommand(const Level& level, const string& command) {
    stringstream commandStream(command);
    string word;
    commandStream >> word;

    string remainingText;
    getline(commandStream, remainingText);
    remainingText = trim(remainingText);

    Position position;

    if (remainingText.empty()) {
        if (!promptForInteger("Enter row: ", position.row)) {
            return false;
        }
        if (!promptForInteger("Enter column: ", position.col)) {
            return false;
        }
    }
    else if (!parseTwoStrictInts(
                 remainingText,
                 position.row,
                 position.col)) {
        cout << "Invalid inspect command. Use: inspect ROW COLUMN\n";
        cout << "Example: inspect 3 7\n";
        return true;
    }

    inspectTile(level, position);
    cout << "Inspection does not use a turn.\n";
    return true;
}

// ------------------------------------------------------------
// Guard vision and movement
// ------------------------------------------------------------

bool guardSeesPlayer(const Level& level, int guardIndex) {
    const Guard& guard = *level.guards[guardIndex];
    Position check = nextPosition(
        guard.getPosition(),
        guard.getDirection()
    );

    while (inBounds(level, check)) {
        if (blocksVision(level, check)) {
            return false;
        }

        if (level.player == check) {
            return true;
        }

        // A guard standing between another guard and the player blocks sight.
        if (findGuard(level, check) != -1) {
            return false;
        }

        check = nextPosition(check, guard.getDirection());
    }

    return false;
}

bool anyGuardSeesPlayer(const Level& level) {
    for (int index = 0;
         index < static_cast<int>(level.guards.size());
         index++) {
        if (guardSeesPlayer(level, index)) {
            return true;
        }
    }

    return false;
}

bool moveGuardTo(Level& level, int guardIndex, Position destination) {
    level.guards[guardIndex]->setPosition(destination);
    activateSwitchAt(level, destination);

    if (destination == level.player) {
        cout << "A guard moved onto your tile.\n";
        return true;
    }

    return false;
}

bool moveGuards(Level& level) {
    for (int index = 0;
         index < static_cast<int>(level.guards.size());
         index++) {
        Guard& guard = *level.guards[index];
        Position destination = nextPosition(
            guard.getPosition(),
            guard.getDirection()
        );

        if (!guardTileBlocked(level, destination, index)) {
            if (moveGuardTo(level, index, destination)) {
                return true;
            }
            continue;
        }

        guard.turnWhenBlocked();

        if (!guard.movesAfterTurning()) {
            continue;
        }

        // A patrol guard turns clockwise and tries to move during this turn.
        destination = nextPosition(
            guard.getPosition(),
            guard.getDirection()
        );

        if (!guardTileBlocked(level, destination, index)) {
            if (moveGuardTo(level, index, destination)) {
                return true;
            }
        }
    }

    return false;
}

MoveResult movePlayer(Level& level, Direction direction) {
    Position destination = nextPosition(level.player, direction);

    if (blocksMovement(level, destination)) {
        cout << "You cannot move there. A wall or closed door is blocking you.\n";
        return MoveResult::Blocked;
    }

    if (findGuard(level, destination) != -1) {
        cout << "You walked into a guard.\n";
        return MoveResult::Caught;
    }

    level.player = destination;
    activateSwitchAt(level, destination);
    return MoveResult::Moved;
}

bool commandToDirection(const string& command, Direction& direction) {
    if (command == "w" || command == "up") {
        direction = Direction::Up;
        return true;
    }
    if (command == "d" || command == "right") {
        direction = Direction::Right;
        return true;
    }
    if (command == "s" || command == "down") {
        direction = Direction::Down;
        return true;
    }
    if (command == "a" || command == "left") {
        direction = Direction::Left;
        return true;
    }

    return false;
}

// ------------------------------------------------------------
// Game loop
// ------------------------------------------------------------

void playLevel(const Level& originalLevel) {
    // A deep copy resets the level every time it is selected.
    Level level(originalLevel);

    while (true) {
        printMap(level);

        // This also checks whether the starting position is visible.
        if (anyGuardSeesPlayer(level)) {
            cout << "A guard spotted you. Game over.\n";
            return;
        }

        string command;
        if (!readLine("Command: ", command)) {
            cout << "\nInput ended. Leaving the game.\n";
            return;
        }

        command = toLower(trim(command));

        if (command == "q" || command == "quit") {
            cout << "Leaving this level.\n";
            return;
        }

        bool isInspect =
            command == "i" ||
            command == "inspect" ||
            command.rfind("i ", 0) == 0 ||
            command.rfind("inspect ", 0) == 0;

        if (isInspect) {
            if (!handleInspectCommand(level, command)) {
                cout << "\nInput ended. Leaving the game.\n";
                return;
            }
            continue;
        }

        Direction direction;
        if (!commandToDirection(command, direction)) {
            cout << "Invalid command. Use W, A, S, D, inspect, or quit.\n";
            continue;
        }

        MoveResult result = movePlayer(level, direction);

        if (result == MoveResult::Blocked) {
            // A blocked movement does not use the player's turn.
            continue;
        }

        if (result == MoveResult::Caught) {
            cout << "Game over.\n";
            return;
        }

        if (level.player == level.goal) {
            printMap(level);
            cout << "You reached the goal. You win!\n";
            return;
        }

        // Vision is checked immediately after the player moves.
        if (anyGuardSeesPlayer(level)) {
            cout << "A guard spotted you. Game over.\n";
            return;
        }

        if (moveGuards(level)) {
            cout << "Game over.\n";
            return;
        }

        // Vision is checked again after all guards move.
        if (anyGuardSeesPlayer(level)) {
            cout << "A guard spotted you. Game over.\n";
            return;
        }
    }
}

int main() {
    try {
        vector<Level> levels = makeLevels();

        cout << "Ultimate Spy - Portfolio 2\n";

        while (true) {
            cout << "\nChoose a level:\n";
            for (int index = 0;
                 index < static_cast<int>(levels.size());
                 index++) {
                cout << index + 1 << ". " << levels[index].name << '\n';
            }
            cout << "0. Quit\n";

            string input;
            if (!readLine("Choice: ", input)) {
                cout << "\nGoodbye.\n";
                break;
            }

            int choice;
            if (!parseStrictInt(trim(input), choice)) {
                cout << "Please enter one valid menu number.\n";
                continue;
            }

            if (choice == 0) {
                cout << "Goodbye.\n";
                break;
            }

            if (choice < 1 || choice > static_cast<int>(levels.size())) {
                cout << "Invalid level choice.\n";
                continue;
            }

            playLevel(levels[choice - 1]);
        }
    }
    catch (const exception& error) {
        cerr << "The game could not start: " << error.what() << '\n';
        return 1;
    }

    return 0;
}